modules = ["bash", "nix"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build & Run"

[[workflows.workflow]]
name = "Build & Run"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gcc -g main.c treemap.c -o main && ./main"

[workflows.workflow.metadata]
outputType = "console"
